; Configuración PHP recomendada para producción
; Copiar estas configuraciones a tu php.ini o crear un archivo separado
; y cargarlo con: php_admin_value[include_path] = "/etc/php/8.2/fpm/conf.d/production.ini"

; ============================================
; OPCACHE - Cache de PHP (MUY IMPORTANTE)
; ============================================
opcache.enable=1
opcache.enable_cli=0
opcache.memory_consumption=256
opcache.interned_strings_buffer=16
opcache.max_accelerated_files=20000
opcache.validate_timestamps=0
opcache.revalidate_freq=0
opcache.save_comments=1
opcache.fast_shutdown=1

; ============================================
; Límites de recursos
; ============================================
max_execution_time=300
max_input_time=300
memory_limit=256M
post_max_size=20M
upload_max_filesize=20M

; ============================================
; Seguridad
; ============================================
expose_php=Off
display_errors=Off
display_startup_errors=Off
log_errors=On
error_log=/var/log/php8.2-fpm.log
error_reporting=E_ALL & ~E_DEPRECATED & ~E_STRICT

; ============================================
; Sesiones
; ============================================
session.cookie_httponly=1
session.cookie_secure=1
session.use_strict_mode=1
session.cookie_samesite=Strict

; ============================================
; Date/Time
; ============================================
date.timezone=America/Lima

